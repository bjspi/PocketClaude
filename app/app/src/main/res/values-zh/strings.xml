    <string name="settings_section_profile_server">配置 &amp; 服务器</string>
    <string name="settings_info_profile_server_title">我的手机如何与服务器连接?</string>
    <string name="settings_info_profile_server_para1">每个配置文件都是独立的服务器端点,带有自己的用户名。你可以并行保留多个配置(例如家里 + 外出),并在下方列表中切换。</string>
    <string name="settings_info_profile_server_url_label">服务器地址:</string>
    <string name="settings_info_profile_server_url_body">当服务器在你的 Mac 上运行时,通常会启动 Cloudflare Quick Tunnel,地址类似 https://abc-xyz-123.trycloudflare.com。在家中 Wi-Fi 下,http://&lt;Mac-IP&gt;:8787 也可用。</string>
    <string name="settings_info_profile_server_login_label">登录:</string>
    <string name="settings_info_profile_server_login_body">首次登录使用服务器管理员的初始密码。然后服务器会强制你设置自己的密码。手机端无 API 密钥。</string>
    <string name="settings_section_claude">Claude</string>
    <string name="settings_info_claude_title">推理强度、角色、技能</string>
    <string name="settings_info_claude_effort_label">推理强度:</string>
    <string name="settings_info_claude_effort_body">Claude 在回答前进行多少内部推理。越高 = 困难问题质量越好,等待时间越长。`xhigh` 仅 Opus 4.7 可用,介于 `high` 和 `max` 之间。</string>
    <string name="settings_info_claude_prompt_label">系统提示词:</string>
    <string name="settings_info_claude_prompt_body">标准 = Anthropic 默认设置,与 claude.ai 一致。宽松 = 中性的成人对成人变体,较少回避。超自由 = 最小限制层,仅硬性底线(未成年人安全、非法合成/恶意软件)。自定义 = 完全使用你自己的提示词。</string>
    <string name="settings_info_claude_skills_label">技能:</string>
    <string name="settings_info_claude_skills_body">Claude 可使用哪些工具 — WebSearch、WebFetch、代码执行。这些是新聊天的默认值。可通过聊天右上角的 ⋮ 菜单为单个聊天覆盖。</string>
    <string name="settings_subsection_effort">推理强度</string>
    <string name="settings_subsection_system_prompt">系统提示词</string>
    <string name="settings_custom_system_prompt_label">自定义系统提示词</string>
    <string name="settings_custom_system_prompt_placeholder">在此粘贴完整的系统提示词…</string>
    <string name="settings_custom_system_prompt_hint">为空 = 使用标准提示词。</string>
    <string name="settings_subsection_skills_defaults">技能 — 新聊天默认</string>
    <string name="settings_info_tts_title">语音输出 — 三种配置路径</string>
    <string name="settings_info_tts_intro">Pocket Claude 可朗读 Claude 的回复。共有三种服务提供方 — 从&quot;零配置&quot;到&quot;高级语音质量&quot;。</string>
    <string name="settings_info_tts_edge_label">Edge(默认,无需配置):</string>
    <string name="settings_info_tts_edge_body">Microsoft Edge 朗读语音。完全免费,无需 API 密钥或服务账户。质量比 Gemini/Chirp 机械,但可立即试用 TTS。</string>
    <string name="settings_info_tts_gemini_label">Gemini API(使用 AI Studio 密钥):</string>
    <string name="settings_info_tts_gemini_body">免费档:每个密钥每天 10 次调用 — 单密钥紧张,多密钥池较好。付费:输入 $0.50/M + 音频输出 $10/M。最佳模型推理。</string>
    <string name="settings_info_tts_cloud_label">Cloud TTS(使用服务账户):</string>
    <string name="settings_info_tts_cloud_body">Chirp 3 HD 每月免费 100 万字符(约 20 小时音频)。最佳语音质量。配置较复杂(Cloud 项目 + 服务账户 JSON)。</string>
    <string name="settings_info_images_title">配置图片生成</string>
    <string name="settings_info_images_intro">图片生成需要 Google AI Studio 的 API 密钥。它按配置存储在服务器端,可选择与 Gemini 语音输出共用。</string>
    <string name="settings_info_images_step1">1.</string>
    <string name="settings_info_images_step1_body">https://aistudio.google.com → 使用你的 Google 账户登录。</string>
    <string name="settings_info_images_step2">2.</string>
    <string name="settings_info_images_step2_body">左侧 &quot;API keys&quot; → &quot;Create API key&quot;。密钥以 &quot;AIza…&quot; 开头。</string>
    <string name="settings_info_images_step3">3.</string>
    <string name="settings_info_images_step3_body">将密钥粘贴到下方字段。</string>
    <string name="settings_info_images_free_label">免费档:</string>
    <string name="settings_info_images_free_body">无需信用卡即可使用(生成密钥时选择 &quot;Create in new project&quot;)。每分钟 15 次,每天 1,500 次。</string>
    <string name="settings_info_images_paid_label">付费档:</string>
    <string name="settings_info_images_paid_body">更高的速率限制,不用于训练。Nano-Banana 约 $0.04/张。</string>
    <string name="settings_images_shared_key_hint">💡 同一密钥也适用于 Gemini TTS 语音输出(&quot;朗读&quot;部分)。如果那里未单独配置密钥,服务器会自动使用此密钥。</string>
    <string name="settings_data_info_title">两种不同的备份类型</string>
    <string name="settings_data_chat_backup_label">聊天备份:</string>
    <string name="settings_data_chat_backup_body">所有会话 + 附件,以加密 ZIP 形式(AES-256)。导入时:&quot;替换&quot;覆盖,&quot;合并&quot;合并。</string>
    <string name="settings_data_settings_backup_label">设置备份:</string>
    <string name="settings_data_settings_backup_body">TTS 服务提供方、完整 API 密钥池、图片 API 密钥、技能、语音、主题、推理强度、系统提示词 — 以 JSON 形式。警告:API 密钥为明文,请像保护密码一样保护此文件。</string>
    <string name="settings_data_no_profiles_body">两种备份都不包含配置文件(服务器地址、用户名、令牌)— 这些数据保留在每台设备本地。</string>
