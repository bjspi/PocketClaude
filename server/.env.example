# Pocket Claude Server — Environment Variables
# Kopiere diese Datei nach .env und passe die Werte an.

# === Pflicht ===

# Auth-Token, das App und Server teilen. Mit `python3 -c "import secrets; print(secrets.token_urlsafe(32))"` generieren.
SERVER_TOKEN=change-me-to-a-long-random-string

# === Optional ===

# Optional: spezifisches Modell überschreiben. Default = was Claude Code default
# für Deine Subscription ist (Sonnet bei Pro, wählbar bei Max).
# Beispiele: "sonnet", "opus", "claude-sonnet-4-5-20250929"
# CLAUDE_MODEL=

# Server-Bindung
SERVER_HOST=0.0.0.0
SERVER_PORT=8787

# Datenverzeichnis (SQLite-DB und Uploads)
DATA_DIR=./data

# Maximale Upload-Größe in MB
MAX_UPLOAD_MB=20

# Log-Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
