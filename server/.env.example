# Pocket Claude Server — Environment Variables
# Copy this file to .env and adjust the values.

# === Required ===

# Auth token shared between app and server. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SERVER_TOKEN=change-me-to-a-long-random-string

# === Optional ===

# Override the specific model. Default = whatever Claude Code defaults to for
# your subscription (Sonnet on Pro, configurable on Max).
# Examples: "sonnet", "opus", "claude-sonnet-4-5-20250929"
# CLAUDE_MODEL=

# Server binding
SERVER_HOST=0.0.0.0
SERVER_PORT=8787

# Data directory (SQLite database + uploads)
DATA_DIR=./data

# Maximum upload size in MB
MAX_UPLOAD_MB=20

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
