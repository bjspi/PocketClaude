# Pocket Claude Server — Environment Variables
# Copy this file to .env and adjust the values.

# === Required ===

# Auth token shared between app and server. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SERVER_TOKEN=change-me-to-a-long-random-string

# === Optional ===

# Override the specific model. Default = whatever Claude Code defaults to for
# your subscription (Sonnet on Pro, configurable on Max).
# Examples: "sonnet", "opus", "claude-sonnet-4-5-20250929"
# CLAUDE_MODEL=

# Optional absolute path if claude is installed but not on the service user's PATH.
# The installer sets this automatically when it can safely detect the binary.
# CLAUDE_BINARY=/usr/local/bin/claude

# Server binding
SERVER_HOST=127.0.0.1
SERVER_PORT=8787

# Built-in browser UI. Set to 0 for API-only Android usage.
ENABLE_WEBUI=1

# Data directory (SQLite database + uploads)
DATA_DIR=./data

# Maximum upload size in MB
MAX_UPLOAD_MB=20

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Security: allow Claude to run Bash on the host? Off by default. With this
# off, the "Code execution" toggle in the app is a no-op and Bash is stripped
# from the tool list server-side. Only turn this on if you trust every user
# you've given an account to — Bash runs as the pocket-claude system user.
ALLOW_BASH=0

# Optional: bind this server to a Google Cloud billing account so the
# in-app TTS-spend widget can show your monthly credit + brutto-spend.
# Leave empty to hide the widget.
# POCKET_CLAUDE_BILLING_ACCOUNT_ID=
